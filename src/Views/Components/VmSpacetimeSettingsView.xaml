<UserControl x:Class="ExHyperV.Views.Components.VmSpacetimeSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:d="http://schemas.expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="850" d:DesignWidth="1100">

    <UserControl.Resources>
        <!-- 完美无缝、边共享正六边形矩阵 -->
        <!-- 计算基准：六边形半径 R = 20 -->
        <!-- 视口宽度 W = R * √3 ≈ 34.64 -->
        <!-- 视口高度 H = R * 3 = 60 -->
        <DrawingBrush x:Key="FineGridBrush" 
              Viewport="0,0,69.28,120" ViewportUnits="Absolute" 
              TileMode="Tile" Stretch="None">
            <DrawingBrush.Drawing>
                <GeometryDrawing>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <!-- 所有数值均由原基础值乘以 2 -->
                            <!-- 1. 上部边缘 -->
                            <PathGeometry Figures="M 0,20 L 34.64,0 L 69.28,20" />

                            <!-- 2. 中部边缘 -->
                            <PathGeometry Figures="M 0,60 L 34.64,80 L 69.28,60" />

                            <!-- 3. 三条垂直共享边 -->
                            <PathGeometry Figures="M 0,20 L 0,60" />
                            <!-- 左侧壁 -->
                            <PathGeometry Figures="M 69.28,20 L 69.28,60" />
                            <!-- 右侧壁 -->
                            <PathGeometry Figures="M 34.64,80 L 34.64,120" />
                            <!-- 底部连接支柱 -->
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#0AFFFFFF" Thickness="1"/>
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="时空管理" FontSize="20" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
            <ui:Button HorizontalAlignment="Right" Appearance="Transparent" Padding="8" Command="{Binding GoBackCommand}">
                <ui:SymbolIcon Symbol="ArrowLeft24" FontSize="18"/>
            </ui:Button>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：时空流动画布 -->
            <Border Grid.Column="0" Background="{ui:ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,12,0" ClipToBounds="True">
                <Grid x:Name="CanvasContainer" Background="{StaticResource FineGridBrush}" MouseDown="CanvasContainer_MouseDown" MouseMove="CanvasContainer_MouseMove" MouseUp="CanvasContainer_MouseUp" MouseLeave="CanvasContainer_MouseLeave">
                    <ScrollViewer x:Name="SpacetimeScrollViewer" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden">
                        <Canvas x:Name="SpacetimeCanvas" Width="3000" Height="2000" Background="Transparent"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 右侧：控制面板 -->
            <StackPanel Grid.Column="1">
                <ui:Card Padding="12">
                    <StackPanel>
                        <TextBlock Text="时空详情" FontSize="14" FontWeight="Medium" Margin="0,0,0,12"/>
                        <Border Background="{ui:ThemeResource ControlFillColorTertiaryBrush}" CornerRadius="6" Padding="12">
                            <Grid>
                                <!-- 1. 未选择提示：默认显示，只有当 SelectedSpacetimeNode 不为 null 时隐藏 -->
                                <TextBlock Text="未选择锚点" FontSize="12" Opacity="0.4" HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <!-- 当选中的节点为空时，显示提示文本 -->
                                                <DataTrigger Binding="{Binding SelectedSpacetimeNode}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- 2. 详情内容：默认隐藏，只有当 SelectedSpacetimeNode 不为 null 时显示 -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <!-- 当选中的节点为空时，隐藏详情内容 -->
                                                <DataTrigger Binding="{Binding SelectedSpacetimeNode}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <TextBlock Text="{Binding SelectedSpacetimeNode.Name}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="SelectedNodeTimeText" Height="16" Text="{Binding SelectedSpacetimeNode.CreatedDate, StringFormat=\{0:yyyy/MM/dd HH:mm:ss\}}" FontSize="11" Opacity="0.6" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <TextBlock Text="操作" FontSize="12" Opacity="0.5" Margin="0,16,0,8"/>

                        <!-- A. [当前] 节点特有操作：创建时空 -->
                        <ui:Button Margin="0,0,0,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="10,8" Appearance="Primary" 
               Command="{Binding CaptureMomentCommand}">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSpacetimeNode.NodeType}" Value="Current">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Add24" FontSize="16"/>
                                <TextBlock Text="创建时空" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </ui:Button>

                        <!-- B. [主时空] 和 [快照] 共有操作：穿梭、虫洞、平行 -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSpacetimeNode.NodeType}" Value="Current">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <ui:Button Margin="0,0,0,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="10,8" Command="{Binding TeleportCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="16"/>
                                    <TextBlock Text="穿梭" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </ui:Button>
                            <ui:Button Margin="0,0,0,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="10,8" Command="{Binding OpenWormholeCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Link24" FontSize="16"/>
                                    <TextBlock Text="开启虫洞" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </ui:Button>
                            <ui:Button Margin="0,0,0,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="10,8" Command="{Binding ParallelSpacetimeCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Copy24" FontSize="16"/>
                                    <TextBlock Text="平行时空" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </ui:Button>
                        </StackPanel>

                        <!-- C. [快照] 节点特有操作：收束、删除 -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSpacetimeNode.NodeType}" Value="Snapshot">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <ui:Button Margin="0,0,0,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="10,8" Command="{Binding ConvergenceCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Merge24" FontSize="16"/>
                                    <TextBlock Text="时间线收束" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </ui:Button>
                            <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="10,8" Appearance="Danger" Command="{Binding AnnihilateCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Delete24" FontSize="16"/>
                                    <TextBlock Text="删除" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </ui:Button>
                        </StackPanel>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>