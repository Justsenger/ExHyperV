<UserControl xmlns:properties="clr-namespace:ExHyperV.Properties" x:Class="ExHyperV.Views.VmSecuritySettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 头部 -->
        <Grid Grid.Row="0" Margin="24,20,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="22" Margin="0,0,12,0" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Static properties:Resources.VmSecurity_Title}" FontSize="20" FontWeight="Normal" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
                <TextBlock Text="{x:Static properties:Resources.VmSecurity_Hint}" FontSize="13" Opacity="0.6" Margin="0,6,0,0" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
            </StackPanel>
            <ui:Button Grid.Column="1" Appearance="Transparent" Padding="8" Command="{Binding GoBackToDashboardCommand}">
                <ui:SymbolIcon Symbol="ArrowLeft24" FontSize="20"/>
            </ui:Button>
        </Grid>

        <!-- 内容（整体仅在第 2 代 + 关机时可改；否则置灰） -->
        <ScrollViewer Grid.Row="1" Margin="24,4,24,24" VerticalScrollBarVisibility="Auto">
            <StackPanel IsEnabled="{Binding SelectedVm.CanEditSecurity}">

                <!-- 安全启动 -->
                <TextBlock Text="{x:Static properties:Resources.VmSecurity_SecureBoot}" FontSize="14" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,0,12"/>
                <Border Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="0" Margin="0,0,0,24">
                    <StackPanel>
                        <Grid Margin="24,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="{x:Static properties:Resources.Xaml_EnableSecureBoot}" FontSize="14" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{x:Static properties:Resources.VmSecurity_SecureBootDesc}" FontSize="12" TextWrapping="Wrap" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsEnabled="{Binding CanEditSecureBoot}" IsChecked="{Binding SecureBootEnabled, Mode=TwoWay}"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{ui:ThemeResource CardStrokeColorDefaultBrush}" Margin="24,0"/>
                        <Grid Margin="24,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static properties:Resources.VmSecurity_Template}" FontSize="14" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                            <ComboBox Grid.Column="1" MinWidth="260" IsEnabled="{Binding CanEditSecureBootTemplate}"
                                      ItemsSource="{Binding SecureBootTemplates}" DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedSecureBootTemplate, Mode=TwoWay}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 加密支持 -->
                <TextBlock Text="{x:Static properties:Resources.VmSecurity_Encryption}" FontSize="14" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,0,12"/>
                <Border Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="0" Margin="0,0,0,24">
                    <StackPanel>
                        <Grid Margin="24,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="{x:Static properties:Resources.Xaml_EnableTpm}" FontSize="14" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{x:Static properties:Resources.VmSecurity_TpmDesc}" FontSize="12" TextWrapping="Wrap" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsEnabled="{Binding CanEditTpm}" IsChecked="{Binding TpmEnabled, Mode=TwoWay}"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{ui:ThemeResource CardStrokeColorDefaultBrush}" Margin="24,0"/>
                        <Grid Margin="24,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="{x:Static properties:Resources.VmSecurity_EncryptMigration}" FontSize="14" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{x:Static properties:Resources.VmSecurity_EncryptMigrationDesc}" FontSize="12" TextWrapping="Wrap" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <!-- 加密迁移是 TPM 的子选项；防护开启时强制开、不可改 -->
                            <ui:ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsEnabled="{Binding CanEditEncryption}" IsChecked="{Binding EncryptionEnabled, Mode=TwoWay}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 安全策略 -->
                <TextBlock Text="{x:Static properties:Resources.VmSecurity_PolicySection}" FontSize="14" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,0,12"/>
                <Border Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="0" Margin="0,0,0,24">
                    <StackPanel>
                        <Grid Margin="24,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="{x:Static properties:Resources.VmSecurity_Shielding}" FontSize="14" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{x:Static properties:Resources.VmSecurity_ShieldingDesc}" FontSize="12" TextWrapping="Wrap" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <!-- 防护随时可开(级联)：开启会自动建/复用 vTPM + 开加密，并锁定安全启动/TPM/加密三开关 -->
                            <ui:ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsEnabled="{Binding CanEditShielding}" IsChecked="{Binding ShieldingEnabled, Mode=TwoWay}"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
