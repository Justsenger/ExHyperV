<UserControl x:Class="ExHyperV.Views.Components.VmConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:tools="clr-namespace:ExHyperV.Tools"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024">

    <Grid Background="#0A0A0A">
        <!-- 
            重点 1：HorizontalAlignment 和 VerticalAlignment 设为 Center 
            当窗口最大化时，Host 控件将保持在 Grid 中央，四周显示黑色背景（黑边）
        -->
        <tools:MsRdpExHost x:Name="RdpHost" 
                           VmId="{Binding VmId}" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center" />

        <!-- 加载遮罩层 -->
        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" 
              Background="#111111" 
              Panel.ZIndex="100">
            <StackPanel VerticalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Width="60" Height="60" Margin="0,0,0,20"/>
                <TextBlock Text="正在建立 Hyper-V 安全会话..." Foreground="Gray" FontSize="16" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>