<ui:FluentWindow
    x:Class="ExHyperV.Views.ConsoleWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:converters="clr-namespace:ExHyperV.Converters"
    xmlns:components="clr-namespace:ExHyperV.Views.Components"
    Title="{Binding VmName}"
    MinWidth="720" 
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </ui:FluentWindow.Resources>
    
    <DockPanel LastChildFill="True" Background="#0A0A0A">
        <ui:TitleBar DockPanel.Dock="Top" Height="42" Padding="0">
            <ui:TitleBar.Header>
                <Grid Margin="12,0,140,0" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- 1. 虚拟机名称 (替换了之前的“控制台”文字) -->
                        <TextBlock Text="{Binding VmName}"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#CCFFFFFF"/>

                        <!-- 2. 电源控制组 (解决了偏移问题) -->
                        <Grid VerticalAlignment="Center">
                            <!-- 状态 A: 未启动 (宽度 60) -->
                            <ui:Button Icon="{ui:SymbolIcon Symbol=Play24}"
                               Appearance="Transparent"
                               Width="60" 
                               Height="32"
                               Padding="0"
                               Command="{Binding StartVmCommand}"
                               ToolTip="启动虚拟机"
                               Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}"/>

                            <!-- 状态 B: 运行时 (缝合怪布局) -->
                            <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <!-- 关机按钮: 只有左边有圆角 -->
                                <ui:Button Icon="{ui:SymbolIcon Symbol=Power24}"
                                   Appearance="Transparent"
                                   Width="36"
                                   Height="32"
                                   Padding="0"
                                   CornerRadius="4,0,0,4"
                                   Command="{Binding ShutdownVmCommand}"
                                   ToolTip="正常关机" />

                                <!-- 下拉按钮: 只有右边有圆角，解决偏移感 -->
                                <ui:DropDownButton Appearance="Transparent"
                                           Width="24"
                                           Height="32"
                                           Padding="0"
                                           Margin="0"
                                           CornerRadius="0,4,4,0"
                                           HorizontalContentAlignment="Center">
                                    <ui:DropDownButton.Flyout>
                                        <ContextMenu>
                                            <MenuItem Header="重启" Command="{Binding ResetVmCommand}">
                                                <MenuItem.Icon>
                                                    <ui:SymbolIcon Symbol="ArrowSync24"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="暂停" Command="{Binding PauseVmCommand}">
                                                <MenuItem.Icon>
                                                    <ui:SymbolIcon Symbol="Pause24"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="保存状态" Command="{Binding SaveVmCommand}">
                                                <MenuItem.Icon>
                                                    <ui:SymbolIcon Symbol="Save24"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="强制关闭" Command="{Binding TurnOffVmCommand}">
                                                <MenuItem.Icon>
                                                    <ui:SymbolIcon Symbol="Flash24" Foreground="#FF4D4F"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </ui:DropDownButton.Flyout>
                                </ui:DropDownButton>
                            </StackPanel>
                        </Grid>

                        <!-- 3. 分辨率切换 -->
                        <ui:DropDownButton Content="{Binding SelectedResolution}" 
                                   Icon="{ui:SymbolIcon Symbol=Desktop24}" 
                                   Appearance="Transparent" 
                                   FontSize="11" 
                                   Height="32"
                                   Padding="8,0" 
                                   Margin="8,0,0,0"
                                   IsEnabled="{Binding CanChangeResolution}">
                            <ui:DropDownButton.Flyout>
                                <ContextMenu ItemsSource="{Binding Resolutions}">
                                    <ContextMenu.ItemContainerStyle>
                                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                            <Setter Property="Header" Value="{Binding}" />
                                            <Setter Property="Command" Value="{Binding DataContext.ChangeResolutionCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}" />
                                            <Setter Property="CommandParameter" Value="{Binding}" />
                                        </Style>
                                    </ContextMenu.ItemContainerStyle>
                                </ContextMenu>
                            </ui:DropDownButton.Flyout>
                        </ui:DropDownButton>

                        <!-- 4. 模式切换 -->
                        <ui:DropDownButton Content="{Binding SelectedSessionMode}" 
                                   Appearance="Transparent" 
                                   FontSize="11" 
                                   Height="32"
                                   Padding="8,0"
                                   Margin="8,0,0,0">
                            <ui:DropDownButton.Icon>
                                <ui:SymbolIcon Symbol="{Binding SelectedSessionIcon}" FontSize="14">
                                    <ui:SymbolIcon.Style>
                                        <Style TargetType="ui:SymbolIcon">
                                            <Setter Property="Foreground" Value="Gray" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnhancedMode}" Value="True">
                                                    <Setter Property="Foreground" Value="#FFCC00" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:SymbolIcon.Style>
                                </ui:SymbolIcon>
                            </ui:DropDownButton.Icon>
                            <ui:DropDownButton.Flyout>
                                <ContextMenu>
                                    <MenuItem Header="基本会话" Command="{Binding SwitchSessionModeCommand}" CommandParameter="基本会话" />
                                    <MenuItem Header="增强会话" Command="{Binding SwitchSessionModeCommand}" CommandParameter="增强会话" />
                                </ContextMenu>
                            </ui:DropDownButton.Flyout>
                        </ui:DropDownButton>

                        <!-- 5. 键盘按钮 (CAD) -->
                        <ui:Button Appearance="Transparent" 
                           Width="38"
                           Height="32"
                           Padding="0"
                           Margin="8,0,0,0"
                           Command="{Binding SendCadCommand}"
                           ToolTip="发送 Ctrl+Alt+Del">
                            <ui:SymbolIcon Symbol="Keyboard24" FontSize="16" />
                        </ui:Button>

                    </StackPanel>
                </Grid>
            </ui:TitleBar.Header>
        </ui:TitleBar>
        <components:VmConsoleView x:Name="ConsoleHost" />
    </DockPanel>
</ui:FluentWindow>