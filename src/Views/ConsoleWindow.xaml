<ui:FluentWindow
    x:Class="ExHyperV.Views.ConsoleWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:converters="clr-namespace:ExHyperV.Converters"
    xmlns:components="clr-namespace:ExHyperV.Views.Components"
    Title="{Binding VmName}"
    MinWidth="720" 
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:FullScreenToStyleConverter x:Key="FullScreenToStyleConverter" />
        <converters:FullScreenToStateConverter x:Key="FullScreenToStateConverter" />

        <Style TargetType="ui:FluentWindow" BasedOn="{StaticResource {x:Type ui:FluentWindow}}">
            <!-- 核心修复：添加 Mode=OneWay -->
            <Setter Property="WindowStyle" Value="{Binding IsFullScreen, Converter={StaticResource FullScreenToStyleConverter}, Mode=OneWay}" />
            <Setter Property="WindowState" Value="{Binding IsFullScreen, Converter={StaticResource FullScreenToStateConverter}, Mode=OneWay}" />
            <Setter Property="Topmost" Value="{Binding IsFullScreen, Mode=OneWay}" />
        </Style>
    </ui:FluentWindow.Resources>
    
    <DockPanel LastChildFill="True" Background="#0A0A0A">
        <!-- 全屏时，Visibility 会变为 Collapsed，释放顶部 42 像素空间 -->
        <ui:TitleBar 
            DockPanel.Dock="Top" 
            Height="42" 
            Padding="0"
            Visibility="{Binding IsFullScreen, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
            <ui:TitleBar.Header>
                <Grid Margin="12,0,140,0" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding VmName}"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           MouseLeftButtonDown="OnHeaderMouseLeftButtonDown"
                           Foreground="#CCFFFFFF"/>

                        <Grid VerticalAlignment="Center">
                            <!-- 启动按钮 -->
                            <ui:Button Icon="{ui:SymbolIcon Symbol=Play24}"
                               Appearance="Transparent"
                               Width="60" 
                               Height="32"
                               Padding="0"
                               Command="{Binding StartVmCommand}"
                               ToolTip="启动虚拟机"
                               Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}"/>

                            <!-- 运行状态按钮组 -->
                            <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ui:Button Icon="{ui:SymbolIcon Symbol=Power24}"
                                   Appearance="Transparent"
                                   Width="36"
                                   Height="32"
                                   Padding="0"
                                   CornerRadius="4,0,0,4"
                                   Command="{Binding ShutdownVmCommand}"
                                   ToolTip="正常关机" />

                                <ui:DropDownButton Appearance="Transparent"
                                           Width="24"
                                           Height="32"
                                           Padding="0,0,8,0"
                                           Margin="0"
                                           CornerRadius="0,4,4,0"
                                           HorizontalContentAlignment="Center"
                                           IsEnabled="{Binding IsNotBusy}">
                                    <ui:DropDownButton.Flyout>
                                        <ContextMenu>
                                            <MenuItem Header="重启" Command="{Binding ResetVmCommand}">
                                                <MenuItem.Icon>
                                                    <ui:SymbolIcon Symbol="ArrowSync24"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="暂停" Command="{Binding PauseVmCommand}">
                                                <MenuItem.Icon>
                                                    <ui:SymbolIcon Symbol="Pause24"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="保存状态" Command="{Binding SaveVmCommand}">
                                                <MenuItem.Icon>
                                                    <ui:SymbolIcon Symbol="Save24"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="强制关闭" Command="{Binding TurnOffVmCommand}">
                                                <MenuItem.Icon>
                                                    <ui:SymbolIcon Symbol="Flash24" Foreground="#FF4D4F"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </ui:DropDownButton.Flyout>
                                </ui:DropDownButton>

                            </StackPanel>
                        </Grid>

                        <ui:DropDownButton Content="{Binding SelectedResolution}" 
                                   Icon="{ui:SymbolIcon Symbol=Desktop24}" 
                                   Appearance="Transparent" 
                                   FontSize="16" 
                                   Height="32"
                                   Padding="8,0" 
                                   Margin="8,0,0,0"
                                   IsEnabled="{Binding CanChangeResolution}">
                            <ui:DropDownButton.Flyout>
                                <ContextMenu ItemsSource="{Binding Resolutions}">
                                    <ContextMenu.ItemContainerStyle>
                                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                            <Setter Property="Header" Value="{Binding}" />
                                            <Setter Property="Command" Value="{Binding DataContext.ChangeResolutionCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}" />
                                            <Setter Property="CommandParameter" Value="{Binding}" />
                                        </Style>
                                    </ContextMenu.ItemContainerStyle>
                                </ContextMenu>
                            </ui:DropDownButton.Flyout>
                        </ui:DropDownButton>

                        <ui:DropDownButton Content="{Binding SelectedSessionMode}" 
                           Appearance="Transparent" 
                           FontSize="11" 
                           Height="32"
                           Padding="8,0"
                           Margin="8,0,0,0">
                            <ui:DropDownButton.Flyout>
                                <ContextMenu>
                                    <MenuItem Header="基本会话" Command="{Binding SwitchSessionModeCommand}" CommandParameter="基本会话" />
                                    <MenuItem Header="增强会话" Command="{Binding SwitchSessionModeCommand}" CommandParameter="增强会话" />
                                </ContextMenu>
                            </ui:DropDownButton.Flyout>
                        </ui:DropDownButton>

                        <ui:Button Appearance="Transparent" 
                                   Width="38"
                                   Height="32"
                                   Padding="0"
                                   Margin="8,0,0,0"
                                   Command="{Binding SendCadCommand}"
                                   ToolTip="发送 Ctrl+Alt+Del">
                            <ui:SymbolIcon Symbol="Keyboard24" FontSize="16" />
                        </ui:Button>

                        
                        <!-- 全屏切换按钮 -->
                        <ui:Button Icon="{ui:SymbolIcon Symbol=FullScreenMaximize24}"
                                   Appearance="Transparent"
                                   Height="32"
                                   Padding="8,0"
                                   Margin="8,0,0,0"
                                   Command="{Binding ToggleFullScreenCommand}"
                                   ToolTip="全屏模式 (Ctrl+Alt+Enter)" />
                    </StackPanel>
                </Grid>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- 虚拟机画面容器 -->
        <components:VmConsoleView x:Name="ConsoleHost" />
    </DockPanel>
</ui:FluentWindow>