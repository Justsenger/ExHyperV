<ui:FluentWindow
    x:Class="ExHyperV.Views.ConsoleWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:components="clr-namespace:ExHyperV.Views.Components"
    Title="{Binding VmName}"
    MinWidth="720" 
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica">

    <DockPanel LastChildFill="True" Background="#0A0A0A">
        <ui:TitleBar DockPanel.Dock="Top" Height="42" Padding="0">
            <ui:TitleBar.Header>
                <Grid Margin="12,0,140,0" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="180"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 1. 左侧：控制组 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="控制台" FontSize="12" FontWeight="SemiBold" Foreground="#EEEEEE" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <ui:Button Appearance="Transparent" Padding="6" Margin="0,0,2,0" ToolTip="启动">
                            <ui:SymbolIcon Symbol="Play24" FontSize="16"/>
                        </ui:Button>
                        <ui:Button Appearance="Transparent" Padding="6" Margin="0,0,2,0" ToolTip="重启">
                            <ui:SymbolIcon Symbol="ArrowSync24" FontSize="16"/>
                        </ui:Button>
                        <ui:Button Appearance="Transparent" Padding="6" ToolTip="发送 Ctrl+Alt+Del">
                            <ui:SymbolIcon Symbol="Keyboard24" FontSize="16"/>
                        </ui:Button>
                    </StackPanel>

                    <!-- 2. 右侧：参数切换组 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- 分辨率下拉 -->
                        <ui:DropDownButton 
    Content="{Binding SelectedResolution}" 
    Icon="{ui:SymbolIcon Symbol=Desktop24}"
    Appearance="Transparent"
    FontSize="11"
    Padding="8,4"
    IsEnabled="{Binding CanChangeResolution}">
                            <ui:DropDownButton.Flyout>
                                <ContextMenu ItemsSource="{Binding Resolutions}">
                                    <ContextMenu.ItemContainerStyle>
                                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                            <Setter Property="Header" Value="{Binding}" />
                                            <!-- 绑定到 ViewModel 的 ChangeResolutionCommand -->
                                            <!-- 因为 ContextMenu 的 DataContext 默认是 String，所以要用 RelativeSource 找 Window -->
                                            <Setter Property="Command" Value="{Binding DataContext.ChangeResolutionCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}" />
                                            <Setter Property="CommandParameter" Value="{Binding}" />
                                        </Style>
                                    </ContextMenu.ItemContainerStyle>
                                </ContextMenu>
                            </ui:DropDownButton.Flyout>
                        </ui:DropDownButton>
                        
                        <Rectangle Width="1" Height="14" Fill="#33FFFFFF" Margin="6,0"/>

                        <!-- 会话模式下拉：修复此处 -->
                        <ui:DropDownButton 
                            Content="{Binding SelectedSessionMode}"
                            Appearance="Transparent"
                            FontSize="11"
                            Padding="8,4">
                            <ui:DropDownButton.Icon>
                                <ui:SymbolIcon Symbol="{Binding SelectedSessionIcon}" FontSize="14">
                                    <ui:SymbolIcon.Style>
                                        <Style TargetType="ui:SymbolIcon">
                                            <Setter Property="Foreground" Value="Gray" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnhancedMode}" Value="True">
                                                    <Setter Property="Foreground" Value="#FFCC00" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:SymbolIcon.Style>
                                </ui:SymbolIcon>
                            </ui:DropDownButton.Icon>
                            <ui:DropDownButton.Flyout>
                                <ContextMenu>
                                    <MenuItem Header="基本会话" 
                                              Command="{Binding SwitchSessionModeCommand}" 
                                              CommandParameter="基本会话" />
                                    <MenuItem Header="增强会话" 
                                              Command="{Binding SwitchSessionModeCommand}" 
                                              CommandParameter="增强会话" />
                                </ContextMenu>
                            </ui:DropDownButton.Flyout>
                        </ui:DropDownButton>
                    </StackPanel>
                </Grid>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <components:VmConsoleView x:Name="ConsoleHost" />
    </DockPanel>
</ui:FluentWindow>