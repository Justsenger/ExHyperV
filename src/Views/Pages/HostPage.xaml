<Page
    x:Class="ExHyperV.Views.HostPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:converters="clr-namespace:ExHyperV.Converters"
    xmlns:properties="clr-namespace:ExHyperV.Properties"
    Title="HostPage">

    <Page.Resources>
    </Page.Resources>

    <Grid Margin="24">
        <StackPanel>
            <StackPanel Margin="0,0,0,12">
                <ui:TextBlock Text="{x:Static properties:Resources.Menu_Env}" FontSize="28" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
            </StackPanel>

            <!-- 第一部分：环境检测 -->
            <StackPanel Margin="0,0,0,16">
                <ui:TextBlock Text="{x:Static properties:Resources.Label_ReqGeneral}"
                              Margin="0,0,0,8"
                              Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>

                <!-- CPU 虚拟化 -->
                <ui:Card Padding="16" Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
                            <ui:ProgressRing Width="16" Height="16" IsIndeterminate="True"
                                             Visibility="{Binding CpuStatus.IsChecking, Converter={StaticResource BoolToVis}}"/>
                            <ui:FontIcon FontSize="20" FontFamily="{DynamicResource SegoeFluentIcons}"
                                         Glyph="{Binding CpuStatus.IconGlyph}"
                                         Foreground="{Binding CpuStatus.IconColor}"
                                         Visibility="{Binding CpuStatus.IsChecking, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{x:Static properties:Resources.Menu_CpuVirt}" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                    </Grid>
                </ui:Card>

                <!-- Hyper-V 服务 -->
                <ui:Card Padding="16" Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
                            <ui:ProgressRing Width="16" Height="16" IsIndeterminate="True"
                                             Visibility="{Binding HyperVStatus.IsChecking, Converter={StaticResource BoolToVis}}"/>
                            <ui:FontIcon FontSize="20" FontFamily="{DynamicResource SegoeFluentIcons}"
                                         Glyph="{Binding HyperVStatus.IconGlyph}"
                                         Foreground="{Binding HyperVStatus.IconColor}"
                                         Visibility="{Binding HyperVStatus.IsChecking, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Static properties:Resources.Menu_HyperVService}" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{Binding HyperVStatus.StatusText}"
                                       Visibility="{Binding HyperVStatus.StatusText, Converter={StaticResource StringToVisibilityConverter}}"
                                       FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:Button Content="{x:Static properties:Resources.Button_Enable}" Appearance="Primary"
                                       Visibility="{Binding HyperVStatus.IsSuccess, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                       Command="{Binding EnableHyperVCommand}"/>
                            <ui:Button Content="{x:Static properties:Resources.HostPage_Disable}" Appearance="Secondary"
                                       Visibility="{Binding HyperVStatus.IsSuccess, Converter={StaticResource BoolToVis}}"
                                       Command="{Binding DisableHyperVCommand}"/>
                        </StackPanel>
                    </Grid>
                </ui:Card>

                <!-- GPU-PV 要求 -->
                <ui:TextBlock Text="{x:Static properties:Resources.Label_ReqGpuPv}"
                              Margin="0,16,0,8"
                              Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>

                <!-- 系统版本 -->
                <ui:Card Padding="16" Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
                            <ui:ProgressRing Width="16" Height="16" IsIndeterminate="True"
                                             Visibility="{Binding VersionStatus.IsChecking, Converter={StaticResource BoolToVis}}"/>
                            <ui:FontIcon FontSize="20" FontFamily="{DynamicResource SegoeFluentIcons}"
                                         Glyph="{Binding VersionStatus.IconGlyph}"
                                         Foreground="{Binding VersionStatus.IconColor}"
                                         Visibility="{Binding VersionStatus.IsChecking, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="14">
                            <Run Text="{x:Static properties:Resources.Label_SysVer}" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                            <Run Text="{Binding VersionStatus.StatusText}" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                        </TextBlock>
                    </Grid>
                </ui:Card>

                <!-- PCIe 直通要求（仅 DDA 需要） -->
                <ui:TextBlock Text="{x:Static properties:Resources.Label_ReqPcie}"
                              Margin="0,16,0,8"
                              Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>

                <!-- IOMMU / SMMU（x86=IOMMU，ARM=SMMU，IommuLabel 按架构切换） -->
                <ui:Card Padding="16" Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
                            <ui:ProgressRing Width="16" Height="16" IsIndeterminate="True"
                                             Visibility="{Binding IommuStatus.IsChecking, Converter={StaticResource BoolToVis}}"/>
                            <ui:FontIcon FontSize="20" FontFamily="{DynamicResource SegoeFluentIcons}"
                                         Glyph="{Binding IommuStatus.IconGlyph}"
                                         Foreground="{Binding IommuStatus.IconColor}"
                                         Visibility="{Binding IommuStatus.IsChecking, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding IommuLabel}" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                    </Grid>
                </ui:Card>

                <!-- 属于 Windows Server 系统 -->
                <ui:Card Padding="16" Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
                            <ui:ProgressRing Width="16" Height="16" IsIndeterminate="True"
                                             Visibility="{Binding SystemStatus.IsChecking, Converter={StaticResource BoolToVis}}"/>
                            <ui:FontIcon FontSize="20" FontFamily="{DynamicResource SegoeFluentIcons}"
                                         Glyph="{Binding SystemStatus.IconGlyph}"
                                         Foreground="{Binding SystemStatus.IconColor}"
                                         Visibility="{Binding SystemStatus.IsChecking, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{x:Static properties:Resources.Label_ServerSys}" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                    </Grid>
                </ui:Card>

                <!-- USB 直通要求（仅检测宿主侧） -->
                <ui:TextBlock Text="{x:Static properties:Resources.Label_ReqUsb}"
                              Margin="0,16,0,8"
                              Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>

                <!-- usbipd-win -->
                <ui:Card Padding="16" Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
                            <ui:ProgressRing Width="16" Height="16" IsIndeterminate="True"
                                             Visibility="{Binding UsbStatus.IsChecking, Converter={StaticResource BoolToVis}}"/>
                            <ui:FontIcon FontSize="20" FontFamily="{DynamicResource SegoeFluentIcons}"
                                         Glyph="{Binding UsbStatus.IconGlyph}"
                                         Foreground="{Binding UsbStatus.IconColor}"
                                         Visibility="{Binding UsbStatus.IsChecking, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{x:Static properties:Resources.Label_UsbipdInstalled}" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                    </Grid>
                </ui:Card>
            </StackPanel>

            <!-- 第二部分：高级设定 -->
            <StackPanel>
                <ui:TextBlock Text="{x:Static properties:Resources.Menu_Advanced}"
                              Margin="0,0,0,8"
                              Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>

                <!-- 核心调度器 -->
                <ui:CardControl Margin="0,0,0,8" Padding="12">
                    <ui:CardControl.Icon>
                        <ui:FontIcon FontSize="22" FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xEA86;"/>
                    </ui:CardControl.Icon>
                    <ui:CardControl.Header>
                        <TextBlock Text="{x:Static properties:Resources.Menu_Scheduler}" FontSize="14" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                    </ui:CardControl.Header>

                    <ComboBox Width="140"
                              ItemsSource="{Binding SchedulerModes}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Type"
                              SelectedValue="{Binding CurrentSchedulerType, Mode=TwoWay}">
                    </ComboBox>
                </ui:CardControl>

                <!-- NUMA 跨越 -->
                <ui:CardControl Margin="0,0,0,8" Padding="12">
                    <ui:CardControl.Icon>
                        <ui:FontIcon FontSize="22" FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xF57C;"/>
                    </ui:CardControl.Icon>
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{x:Static properties:Resources.Menu_NumaSpan}" FontSize="14" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{x:Static properties:Resources.Desc_NumaSpan}" FontSize="12" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>

                    <ui:ToggleSwitch IsChecked="{Binding IsNumaSpanningEnabled, Mode=TwoWay}"/>
                </ui:CardControl>

                <!-- PCIe 策略 -->
                <ui:CardControl Margin="0,0,0,8" Padding="12">
                    <ui:CardControl.Icon>
                        <ui:FontIcon FontSize="22" FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xED56;"/>
                    </ui:CardControl.Icon>
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{x:Static properties:Resources.Menu_UnlockHard}" FontSize="14" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{x:Static properties:Resources.Desc_UnlockHard}" FontSize="12" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch IsChecked="{Binding IsGpuStrategyEnabled, Mode=TwoWay}"
                                     IsEnabled="{Binding IsGpuStrategyToggleEnabled}"/>
                </ui:CardControl>

                <!-- 系统切换 (服务器版本切换) -->
                <ui:CardControl Margin="0,0,0,8" Padding="12">
                    <ui:CardControl.Icon>
                        <ui:FontIcon FontSize="22" FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xE8D7;"/>
                    </ui:CardControl.Icon>
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{x:Static properties:Resources.Menu_SwitchServer}" FontSize="14" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{x:Static properties:Resources.Desc_SwitchServer}" FontSize="12" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch IsChecked="{Binding IsServerSystem, Mode=TwoWay}"
                                     IsEnabled="{Binding IsSystemSwitchEnabled}"/>
                </ui:CardControl>

                <!-- 宿主原生 NVMe (Windows Server 2025 / Win11 24H2+)。不支持的系统上不隐藏，仅置灰开关。 -->
                <ui:CardControl Margin="0,0,0,8" Padding="12">
                    <ui:CardControl.Icon>
                        <ui:FontIcon FontSize="22" FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xEEA1;"/>
                    </ui:CardControl.Icon>
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{x:Static properties:Resources.Menu_NativeNvme}" FontSize="14" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{x:Static properties:Resources.Desc_NativeNvme}" FontSize="12" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch IsChecked="{Binding IsNativeNvmeEnabled, Mode=TwoWay}"
                                     IsEnabled="{Binding IsNativeNvmeToggleEnabled}"/>
                </ui:CardControl>

            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
